<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <title>Morse Control</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root {
      --bg: #f3efe6;
      --panel: #f8f4ec;
      --text: #111111;
      --muted: #5e5a54;
      --line: #111111;
      --red: #c83a2a;
      --yellow: #d8a317;
      --blue: #1f4fa3;
      --white: #fffdf8;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: Futura, "Avenir Next", "Helvetica Neue", Arial, sans-serif;
      height: 100%;
      overflow: hidden;
    }

    body {
      min-height: 100vh;
      padding: 18px;
    }

    .app {
      max-width: 760px;
      height: calc(100vh - 36px);
      margin: 0 auto;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 14px;
    }

    .top {
      display: grid;
      grid-template-columns: 1fr 150px;
      gap: 14px;
      align-items: start;
    }

    .title {
      display: grid;
      gap: 4px;
    }

    .title h1 {
      margin: 0;
      font-size: clamp(28px, 5vw, 46px);
      line-height: 0.92;
      font-weight: 900;
      letter-spacing: -0.04em;
      text-transform: uppercase;
    }

    .subtitle {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
    }

    .status {
      min-height: 120px;
      border: 3px solid var(--line);
      background: var(--white);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 10px;
      font-size: 20px;
      font-weight: 900;
      text-transform: uppercase;
      line-height: 1;
    }

    .status.disconnected { background: var(--white); color: var(--text); }
    .status.connected { background: var(--blue); color: white; }
    .status.tx { background: var(--red); color: white; }
    .status.stop { background: var(--yellow); color: var(--text); }
    .status.error { background: var(--text); color: white; }

    .panel {
      background: var(--panel);
      border: 3px solid var(--line);
      padding: 14px;
      display: grid;
      gap: 12px;
      min-height: 0;
    }

    .row-2, .row-3 {
      display: grid;
      gap: 10px;
    }

    .row-2 {
      grid-template-columns: 1fr 150px;
    }

    .row-3 {
      grid-template-columns: 1fr 110px 110px;
    }

    .field {
      display: grid;
      gap: 5px;
      min-height: 0;
    }

    label {
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    input, select, textarea, button {
      width: 100%;
      border: 3px solid var(--line);
      border-radius: 0;
      background: var(--white);
      color: var(--text);
      font: inherit;
      outline: none;
      box-shadow: none;
    }

    input, select, textarea {
      padding: 10px 10px;
      font-size: 15px;
    }

    textarea {
      min-height: 0;
      height: 100%;
      resize: none;
      line-height: 1.25;
      overflow: hidden;
    }

    button {
      padding: 10px 10px;
      font-size: 13px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      cursor: pointer;
      transition: transform 0.04s ease;
    }

    button:active {
      transform: translate(2px, 2px);
    }

    .btn-connect {
      background: var(--blue);
      color: white;
    }

    .btn-send {
      background: var(--red);
      color: white;
    }

    .btn-stop {
      background: var(--yellow);
      color: var(--text);
    }

    .btn-plain {
      background: var(--white);
      color: var(--text);
    }

    .actions {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10px;
    }

    .text-block {
      min-height: 0;
      display: grid;
      grid-template-rows: auto 1fr;
    }

    .foot {
      font-size: 10px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
    }

    @media (max-width: 760px) {
      html, body {
        overflow: auto;
      }

      body {
        padding: 14px;
      }

      .app {
        height: auto;
      }

      .top {
        grid-template-columns: 1fr;
      }

      .status {
        min-height: 90px;
      }

      .row-2, .row-3, .actions {
        grid-template-columns: 1fr;
      }

      textarea {
        height: 140px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="top">
      <div class="title">
        <h1>Morse<br>Control</h1>
        <div class="subtitle">Arduino → R5</div>
      </div>

      <div id="statusBox" class="status disconnected">Offline</div>
    </div>

    <section class="panel">
      <div class="row-2">
        <div class="field">
          <label for="port">Puerto</label>
          <select id="port"></select>
        </div>

        <div class="field">
          <label>&nbsp;</label>
          <button class="btn-connect" onclick="connectSerial()">Conectar</button>
        </div>
      </div>

      <div class="field text-block">
        <label for="text">Texto</label>
        <textarea id="text">CQ CQ DE IVAN</textarea>
      </div>

      <div class="row-3">
        <div class="field">
          <label for="baud">Baud</label>
          <input id="baud" type="number" value="115200">
        </div>

        <div class="field">
          <label for="wpm">WPM</label>
          <input id="wpm" type="number" value="15" min="5" max="40">
        </div>

        <div class="field">
          <label for="tone">Hz</label>
          <input id="tone" type="number" value="700" min="300" max="2000">
        </div>
      </div>

      <div class="actions">
        <button class="btn-plain" onclick="loadPorts()">Puertos</button>
        <button class="btn-send" onclick="sendMorse()">Transmitir</button>
        <button class="btn-stop" onclick="stopTx()">Stop</button>
      </div>
    </section>

    <div class="foot">Minimal interface / local control / serial link</div>
  </div>

  <script>
    function setStatus(text, mode = "disconnected") {
      const box = document.getElementById("statusBox");
      box.textContent = text;
      box.className = "status " + mode;
    }

    async function api(url, method = "GET", body = null) {
      const opts = { method, headers: {} };
      if (body) {
        opts.headers["Content-Type"] = "application/json";
        opts.body = JSON.stringify(body);
      }
      const r = await fetch(url, opts);
      return await r.json();
    }

    async function loadPorts() {
      const data = await api("/api/ports");
      const sel = document.getElementById("port");
      sel.innerHTML = "";

      if (!data.ok) {
        setStatus("Error", "error");
        return;
      }

      for (const p of data.ports) {
        const opt = document.createElement("option");
        opt.value = p.device;
        opt.textContent = `${p.device} — ${p.description}`;
        sel.appendChild(opt);
      }
    }

    async function connectSerial() {
      const port = document.getElementById("port").value;
      const baud = parseInt(document.getElementById("baud").value, 10);

      const data = await api("/api/connect", "POST", { port, baud });

      if (!data.ok) {
        setStatus("Error", "error");
        alert(data.error || "Error conectando");
        return;
      }

      setStatus("Ready", "connected");
    }

    async function sendMorse() {
      const text = document.getElementById("text").value;
      const wpm = parseInt(document.getElementById("wpm").value, 10);
      const tone = parseInt(document.getElementById("tone").value, 10);

      const data = await api("/api/send", "POST", { text, wpm, tone });

      if (!data.ok) {
        setStatus("Error", "error");
        alert(data.error || "Error enviando");
        return;
      }

      setStatus("TX", "tx");
    }

    async function stopTx() {
      const data = await api("/api/stop", "POST");

      if (!data.ok) {
        setStatus("Error", "error");
        alert(data.error || "Error stop");
        return;
      }

      setStatus("Stop", "stop");
    }

    async function refreshLogState() {
      const data = await api("/api/log");
      if (!data.ok || !data.log || !data.log.length) return;

      const last = data.log[data.log.length - 1] || "";

      if (last.includes("PONG")) setStatus("Ready", "connected");
      if (last.includes("TX_START")) setStatus("TX", "tx");
      if (last.includes("TX_END")) setStatus("Ready", "connected");
      if (last.includes("TX_STOPPED")) setStatus("Stop", "stop");
      if (last.includes("ERR|")) setStatus("Error", "error");
    }

    (async function init() {
      await loadPorts();
      setStatus("Offline", "disconnected");
      setInterval(refreshLogState, 1000);
    })();
  </script>
</body>
</html>
